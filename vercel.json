<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BBTS — Contratações SPS</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--blue:#465EFF;--blue-lt:#EEF0FF;--green:#2E7D5E;--green-lt:#E6F4EF;--red:#C0392B;--red-lt:#FDECEA;--amber:#E8A020;--amber-lt:#FEF3DC;--bg:#F5F6F8;--white:#fff;--border:#E5E7EB;--text:#111827;--text2:#6B7280;--radius:8px}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);font-size:14px;min-height:100vh}

.header{background:var(--blue);color:#fff;padding:0 28px;height:58px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
.brand-mark{width:32px;height:32px;background:rgba(255,255,255,0.2);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:#fff}
.brand-name{font-size:14px;font-weight:600;letter-spacing:0.03em}
.brand-sub{font-size:11px;opacity:0.65;margin-top:1px}
.btn-voltar{background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);color:#fff;padding:5px 14px;border-radius:6px;font-size:12px;cursor:pointer;text-decoration:none;display:flex;align-items:center;gap:6px;font-family:'Inter',sans-serif}
.btn-voltar:hover{background:rgba(255,255,255,0.25)}
.btn-atualizar{background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);color:#fff;padding:5px 14px;border-radius:6px;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:6px;font-family:'Inter',sans-serif}
.btn-atualizar:hover{background:rgba(255,255,255,0.25)}
.btn-atualizar.spin span{display:inline-block;animation:spin 0.8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

.main{max-width:1280px;margin:0 auto;padding:24px 28px}

.legenda{display:flex;gap:16px;margin-bottom:14px;flex-wrap:wrap}
.leg{display:flex;align-items:center;gap:5px;font-size:12px;color:var(--text2)}
.leg-dot{width:8px;height:8px;border-radius:50%}

.toolbar{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;align-items:center}
.toolbar input,.toolbar select{padding:7px 12px;border:1px solid var(--border);border-radius:var(--radius);font-size:13px;font-family:'Inter',sans-serif;background:var(--white)}
.toolbar input{flex:1;min-width:200px}
.toolbar input:focus,.toolbar select:focus{outline:none;border-color:var(--blue)}

.table-wrap{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:12px}
table{width:100%;border-collapse:collapse;table-layout:fixed}
thead th{padding:10px 14px;text-align:left;font-size:11px;font-weight:500;color:var(--text2);text-transform:uppercase;letter-spacing:0.06em;border-bottom:1px solid var(--border);background:#FAFAFA;white-space:nowrap}
tbody tr{border-bottom:1px solid var(--border);cursor:pointer;transition:background 0.1s}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:#F0F4FF}
tbody td{padding:12px 14px;font-size:13px;vertical-align:middle;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

.sem{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:500;white-space:nowrap}
.sem-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.sem-verde{background:var(--green-lt);color:#1A5C44}.sem-verde .sem-dot{background:var(--green)}
.sem-amarelo{background:var(--amber-lt);color:#7A4E00}.sem-amarelo .sem-dot{background:var(--amber);animation:pulse 1.4s infinite}
.sem-vermelho{background:var(--red-lt);color:#7A1F17}.sem-vermelho .sem-dot{background:var(--red);animation:pulseR .9s infinite}
.sem-cinza{background:#F3F4F6;color:var(--text2)}.sem-cinza .sem-dot{background:#9CA3AF}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
@keyframes pulseR{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.7;transform:scale(1.3)}}

.trilho{display:flex;align-items:flex-start;gap:0;min-width:220px}
.t-step{position:relative;display:flex;flex-direction:column;align-items:center;gap:3px;flex:1}
.t-dot{width:8px;height:8px;border-radius:50%;background:#E5E7EB;border:1.5px solid #D1D5DB;z-index:1}
.t-step.done .t-dot{background:var(--green);border-color:var(--green)}
.t-step.current .t-dot{background:var(--blue);border-color:var(--blue);width:10px;height:10px;box-shadow:0 0 0 3px rgba(70,94,255,.15)}
.t-line{flex:1;height:1.5px;background:#E5E7EB;margin:0 -1px;margin-top:-16px;z-index:0}
.t-line.done{background:var(--green)}
.t-label{font-size:8px;color:var(--text2);text-align:center;line-height:1.2;max-width:36px}
.t-step.done .t-label{color:var(--green)}
.t-step.current .t-label{color:var(--blue);font-weight:500}

.dias-n{font-size:15px;font-weight:500}
.dias-s{font-size:10px;color:var(--text2);display:block}

.pag{display:flex;align-items:center;justify-content:space-between;font-size:12px;color:var(--text2)}
.pag button{padding:4px 12px;border:1px solid var(--border);border-radius:6px;background:var(--white);font-size:12px;cursor:pointer;font-family:'Inter',sans-serif}
.pag button:disabled{opacity:0.4;cursor:default}
.empty{padding:40px;text-align:center;color:var(--text2);font-size:13px}

/* Modal */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:100;align-items:flex-start;justify-content:center;padding-top:48px;overflow-y:auto}
.overlay.open{display:flex}
.modal{background:var(--white);border-radius:12px;width:min(680px,95vw);padding:24px;margin-bottom:48px}
.modal-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border)}
.modal-titulo{font-size:16px;font-weight:500}
.modal-sub{font-size:12px;color:var(--text2);margin-top:3px}
.btn-close{background:none;border:none;cursor:pointer;color:var(--text2);font-size:22px;line-height:1;padding:4px}
.btn-close:hover{color:var(--text)}
.secao{font-size:11px;font-weight:500;color:var(--blue);text-transform:uppercase;letter-spacing:0.08em;padding:6px 0 4px;border-bottom:1.5px solid var(--blue);margin:16px 0 10px}
.secao:first-child{margin-top:0}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.campo{background:#F9FAFB;border-radius:6px;padding:8px 12px;border:1px solid var(--border)}
.campo-l{font-size:10px;color:var(--blue);font-weight:500;letter-spacing:0.05em;margin-bottom:3px;text-transform:uppercase}
.campo-v{font-size:13px;color:var(--text);font-weight:500}
.campo-e{color:var(--text2);font-style:italic;font-size:12px;font-weight:400}
</style>
</head>
<body>

<header class="header">
  <div style="display:flex;align-items:center;gap:12px">
    <div class="brand-mark">SPS</div>
    <div>
      <div class="brand-name">BBTS — Contratações</div>
      <div class="brand-sub" id="sub">Carregando...</div>
    </div>
  </div>
  <div style="display:flex;align-items:center;gap:10px">
    <span style="font-size:11px;color:rgba(255,255,255,0.55)" id="upd">—</span>
    <button class="btn-atualizar" id="btn" onclick="loadData()">
      <span id="ri">↻</span> Atualizar
    </button>
    <a href="/" class="btn-voltar">← Portal</a>
  </div>
</header>

<main class="main">

  <div class="legenda">
    <div class="leg"><div class="leg-dot" style="background:var(--green)"></div> No prazo (≤10 dias úteis)</div>
    <div class="leg"><div class="leg-dot" style="background:var(--amber)"></div> Atenção (11–14 dias)</div>
    <div class="leg"><div class="leg-dot" style="background:var(--red)"></div> Atrasado (≥15 dias)</div>
    <div class="leg"><div class="leg-dot" style="background:#9CA3AF"></div> Concluído</div>
  </div>

  <div class="toolbar">
    <input type="text" id="sq" placeholder="Buscar por SPS ou fiscal..." oninput="applyFilter()" />
    <select id="sf" onchange="applyFilter()">
      <option value="">Todos os status</option>
      <option value="aberto">Em aberto</option>
      <option value="atrasado">Atrasados</option>
      <option value="concluido">Concluídos</option>
    </select>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th style="width:13%">SPS</th>
          <th style="width:18%">Fiscal</th>
          <th style="width:28%">Progresso</th>
          <th style="width:11%">Dias úteis</th>
          <th style="width:14%">Prazo</th>
          <th style="width:10%;text-align:center">Currículos</th>
          <th style="width:6%;text-align:center">Status</th>
        </tr>
      </thead>
      <tbody id="tb">
        <tr><td colspan="7" class="empty">Carregando dados...</td></tr>
      </tbody>
    </table>
  </div>

  <div class="pag">
    <span id="pi">—</span>
    <div style="display:flex;gap:6px">
      <button onclick="changePage(-1)" id="pp">← Anterior</button>
      <button onclick="changePage(1)"  id="pn">Próxima →</button>
    </div>
  </div>
</main>

<!-- Modal -->
<div class="overlay" id="overlay" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <div class="modal-hd">
      <div>
        <div class="modal-titulo" id="m-titulo">—</div>
        <div class="modal-sub" id="m-sub">—</div>
      </div>
      <button class="btn-close" onclick="closeModal()">✕</button>
    </div>
    <div id="mb"></div>
  </div>
</div>

<script>
const API = '/api/notion';
const PER = 15;
let rows = [], filt = [], page = 1;

const ETAPAS = [
  {k:'Aguardando Currículos', l:'E-mail'},
  {k:'Currículos Enviados',   l:'Currículos'},
  {k:'Em Entrevista',         l:'Entrevista'},
  {k:'Candidato Escolhido',   l:'Escolhido'},
  {k:'Aguardando Autorização',l:'Autorização'},
  {k:'Autorizado',            l:'Autorizado'},
  {k:'Em Contratação',        l:'Contratando'},
  {k:'Contratado',            l:'Contratado'},
];
const EI = Object.fromEntries(ETAPAS.map((e,i)=>[e.k,i]));

const FERIADOS = new Set([
  '2025-01-01','2025-04-18','2025-04-21','2025-05-01','2025-06-19',
  '2025-09-07','2025-10-12','2025-11-02','2025-11-15','2025-11-20','2025-12-25',
  '2026-01-01','2026-04-03','2026-04-21','2026-05-01','2026-06-04',
  '2026-09-07','2026-10-12','2026-11-02','2026-11-15','2026-11-20','2026-12-25',
]);

function isDU(d){return d.getDay()!==0&&d.getDay()!==6&&!FERIADOS.has(d.toISOString().slice(0,10));}

function calcDU(s,e,pausas=[]){
  if(!s)return null;
  var sd=new Date(s+'T12:00:00'),ed=new Date((e||new Date().toISOString().slice(0,10))+'T12:00:00');
  var n=0;
  for(var d=new Date(sd);d<=ed;d.setDate(d.getDate()+1)){
    if(!isDU(d))continue;
    var ds=d.toISOString().slice(0,10);
    var p=pausas.some(function(p){return ds>=p.i&&ds<p.f;});
    if(!p)n++;
  }
  return n;
}

function duLiq(r){
  if(!r.data_email)return null;
  var pausas=[];
  if(r.data_curriculos&&r.data_entrevista)pausas.push({i:r.data_curriculos,f:r.data_entrevista});
  if(r.data_escolhido&&r.data_autorizacao)pausas.push({i:r.data_escolhido,f:r.data_autorizacao});
  return calcDU(r.data_email,r.data_admissao||null,pausas);
}

function semaforo(n,status){
  if(['Contratado','Cancelado'].includes(status))return 'cinza';
  if(n===null)return 'cinza';
  if(n<=10)return 'verde';
  if(n<=14)return 'amarelo';
  return 'vermelho';
}

function fmtD(d){if(!d)return '—';var p=d.split('-');return p[2]+'/'+p[1]+'/'+p[0];}

function trilhoHTML(status){
  var idx=EI[status]??0;
  var h='<div class="trilho">';
  ETAPAS.forEach(function(e,i){
    var cls=i<idx?'done':i===idx?'current':'';
    if(i>0)h+='<div class="t-line '+(i<=idx?'done':'')+'"></div>';
    h+='<div class="t-step '+cls+'"><div class="t-dot"></div><div class="t-label">'+e.l+'</div></div>';
  });
  return h+'</div>';
}

function semHTML(n,status){
  var s=semaforo(n,status);
  var map={verde:'No prazo',amarelo:'Atenção',vermelho:'Atrasado',cinza:status==='Contratado'?'Concluído':'—'};
  return '<span class="sem sem-'+s+'"><span class="sem-dot"></span>'+map[s]+'</span>';
}

function statusBadge(st){
  var map={
    'Aguardando Currículos':{bg:'#EEF2FF',c:'#3730A3'},
    'Currículos Enviados':{bg:'#EFF6FF',c:'#1D4ED8'},
    'Em Entrevista':{bg:'#FFF7ED',c:'#C2410C'},
    'Candidato Escolhido':{bg:'#F5F3FF',c:'#6D28D9'},
    'Aguardando Autorização':{bg:'#F9FAFB',c:'#6B7280'},
    'Autorizado':{bg:'#ECFDF5',c:'#065F46'},
    'Em Contratação':{bg:'#EFF6FF',c:'#1E40AF'},
    'Contratado':{bg:'#ECFDF5',c:'#065F46'},
    'Cancelado':{bg:'#FEF2F2',c:'#991B1B'},
  };
  var m=map[st]||{bg:'#F3F4F6',c:'#374151'};
  return '<span style="display:inline-block;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:500;background:'+m.bg+';color:'+m.c+'">'+st+'</span>';
}

function campo(label,val){
  var v=val&&val!=='null'&&val!=='None'?String(val).trim():null;
  return '<div class="campo"><div class="campo-l">'+label+'</div><div class="campo-v">'+(v?v:'<span class="campo-e">Em branco</span>')+'</div></div>';
}

async function loadData(){
  var btn=document.getElementById('btn');
  btn.classList.add('spin');
  try{
    var res=await fetch(API+'?db=solicitacoes');
    var data=await res.json();
    if(data.error)throw new Error(data.error);
    rows=(data.solicitacoes||[]).map(function(s){
      return {
        id:s.id,
        numero_sps:s.numero_sps,
        fiscal:s.fiscal,
        gerente:s.gerente,
        status:s.status,
        data_email:s.data_email,
        data_curriculos:s.data_curriculos,
        data_entrevista:s.data_entrevista,
        data_escolhido:s.data_escolhido,
        data_autorizacao:s.data_autorizacao,
        data_admissao:s.data_admissao,
        total_curriculos:s.total_curriculos,
      };
    });
    document.getElementById('sub').textContent=rows.length+' solicitações';
    document.getElementById('upd').textContent='Atualizado às '+new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
    applyFilter();
  }catch(e){
    document.getElementById('sub').textContent='Erro: '+e.message;
    document.getElementById('tb').innerHTML='<tr><td colspan="7" class="empty">⚠ '+e.message+'</td></tr>';
  }
  btn.classList.remove('spin');
}

function applyFilter(){
  var q=document.getElementById('sq').value.toLowerCase();
  var sf=document.getElementById('sf').value;
  filt=rows.filter(function(r){
    if(q&&!(r.numero_sps||'').toLowerCase().includes(q)&&!(r.fiscal||'').toLowerCase().includes(q))return false;
    if(sf==='aberto'&&['Contratado','Cancelado'].includes(r.status))return false;
    if(sf==='atrasado'){var n=duLiq(r);return semaforo(n,r.status)==='vermelho';}
    if(sf==='concluido'&&r.status!=='Contratado')return false;
    return true;
  });
  page=1;render();
}

function changePage(d){page=Math.max(1,Math.min(Math.ceil(filt.length/PER),page+d));render();}

function render(){
  var tb=document.getElementById('tb');
  var start=(page-1)*PER;
  var slice=filt.slice(start,start+PER);
  var total=filt.length;
  document.getElementById('pi').textContent=total>0?(start+1)+'–'+Math.min(start+PER,total)+' de '+total+' SPS':'0 resultados';
  document.getElementById('pp').disabled=page<=1;
  document.getElementById('pn').disabled=page>=Math.ceil(total/PER);
  if(!slice.length){tb.innerHTML='<tr><td colspan="7" class="empty">Nenhuma SPS encontrada</td></tr>';return;}
  tb.innerHTML=slice.map(function(r,i){
    var n=duLiq(r);
    var sem=semaforo(n,r.status);
    var cor=sem==='vermelho'?'var(--red)':sem==='amarelo'?'var(--amber)':'var(--text)';
    return '<tr onclick="openModal('+(start+i)+')">'+
      '<td style="font-family:monospace;font-size:11px;color:var(--blue);font-weight:500">'+(r.numero_sps||'—')+'</td>'+
      '<td style="color:var(--text2);font-size:12px">'+(r.fiscal||'—')+'</td>'+
      '<td>'+trilhoHTML(r.status)+'</td>'+
      '<td>'+(n!==null?'<span class="dias-n" style="color:'+cor+'">'+n+'</span><span class="dias-s">dias úteis</span>':'<span style="color:var(--text2)">—</span>')+'</td>'+
      '<td>'+semHTML(n,r.status)+'</td>'+
      '<td style="text-align:center;font-family:monospace;color:var(--text2)">'+(r.total_curriculos??'—')+'</td>'+
      '<td style="text-align:center">'+statusBadge(r.status)+'</td>'+
    '</tr>';
  }).join('');
}

function openModal(idx){
  var r=filt[idx];if(!r)return;
  var n=duLiq(r);
  document.getElementById('m-titulo').textContent=r.numero_sps||'SPS';
  document.getElementById('m-sub').textContent='Fiscal: '+(r.fiscal||'—')+' · '+(r.status||'—');
  document.getElementById('mb').innerHTML=
    '<div style="margin-bottom:14px">'+trilhoHTML(r.status)+'</div>'+
    '<div class="secao">Identificação</div>'+
    '<div class="g3">'+campo('Número SPS',r.numero_sps)+campo('Status',statusBadge(r.status))+campo('Currículos enviados',r.total_curriculos)+'</div>'+
    '<div class="g2" style="margin-top:8px">'+campo('Fiscal do Contrato',r.fiscal)+campo('Gerente Demandante',r.gerente)+'</div>'+
    '<div class="secao">Cronograma</div>'+
    '<div class="g3">'+campo('E-mail recebido',fmtD(r.data_email))+campo('Currículos enviados',fmtD(r.data_curriculos))+campo('Pedido de entrevista',fmtD(r.data_entrevista))+'</div>'+
    '<div class="g3" style="margin-top:8px">'+campo('Candidato escolhido',fmtD(r.data_escolhido))+campo('Autorização',fmtD(r.data_autorizacao))+campo('Admissão',fmtD(r.data_admissao))+'</div>'+
    '<div class="secao">Prazo</div>'+
    '<div class="g2">'+campo('Dias úteis líquidos',n!==null?n+' dias úteis':null)+campo('Semáforo',n!==null?semHTML(n,r.status):null)+'</div>';
  document.getElementById('overlay').classList.add('open');
}

function closeModal(){document.getElementById('overlay').classList.remove('open');}

loadData();
</script>
</body>
</html>
